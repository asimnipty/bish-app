{
  "name": "bisharod",
  "version": "1.0.0",
  "description": "Bisharod - Expert Collaboration Platform",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd bisharod-backend && npm install && cd ../bisharod-frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd bisharod-backend && npm run dev",
    "dev:frontend": "cd bisharod-frontend && npm run dev",
    "build": "cd bisharod-frontend && npm run build",
    "start": "cd bisharod-backend && npm start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "mern",
    "expert-platform",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Bisharod Team",
  "license": "ISC",
  "dependencies": {
    "react-router-dom": "^7.14.0"
  }
}
